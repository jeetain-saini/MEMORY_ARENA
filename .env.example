# =============================================================================
# MemoryArena — Environment Template
# Copy to `.env` and fill in real values. NEVER commit the populated `.env`.
# =============================================================================

# ----------------------------------------------------------------------------
# Application
# ----------------------------------------------------------------------------
APP_NAME=MemoryArena
APP_ENV=development              # development | staging | production
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
APP_SECRET_KEY=change-me-to-a-long-random-string
LOG_LEVEL=INFO                   # DEBUG | INFO | WARNING | ERROR

# ----------------------------------------------------------------------------
# PostgreSQL + pgvector  (primary store + semantic vectors)
# ----------------------------------------------------------------------------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=memoryarena
POSTGRES_PASSWORD=change-me
POSTGRES_DB=memoryarena
# SQLAlchemy async URL (assembled from the parts above in core/config)
DATABASE_URL=postgresql+asyncpg://memoryarena:change-me@postgres:5432/memoryarena
PGVECTOR_DIMENSIONS=1536         # must match the embedding model's output size

# ----------------------------------------------------------------------------
# Neo4j  (knowledge graph — entity & relationship memory)
# ----------------------------------------------------------------------------
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change-me
NEO4J_DATABASE=neo4j

# ----------------------------------------------------------------------------
# Redis  (cache, rate limiting, background queues)
# ----------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_URL=redis://redis:6379/0

# ----------------------------------------------------------------------------
# LLM / Embeddings  (LangChain / LangGraph providers)
# ----------------------------------------------------------------------------
# Default to the latest, most capable Claude model for extraction/consolidation.
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
LLM_MODEL=claude-opus-4-8
EMBEDDING_PROVIDER=openai
OPENAI_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small

# LangSmith tracing (optional, for workflow observability)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=memoryarena

# ----------------------------------------------------------------------------
# Auth / Security
# ----------------------------------------------------------------------------
JWT_SECRET_KEY=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ----------------------------------------------------------------------------
# Frontend (Next.js)  — variables exposed to the browser must be NEXT_PUBLIC_*
# ----------------------------------------------------------------------------
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_APP_NAME=MemoryArena
