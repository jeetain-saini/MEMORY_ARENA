{
  "__comment": "MemoryArena observability dashboard (Phase 4.2). Import into Grafana with a Prometheus datasource.",
  "title": "MemoryArena",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "title": "Retrieval latency (ms)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        { "expr": "memoryarena_retrieval_latency_ms{quantile=\"0.5\"}", "legendFormat": "p50" },
        { "expr": "memoryarena_retrieval_latency_ms{quantile=\"0.95\"}", "legendFormat": "p95" }
      ]
    },
    {
      "id": 2,
      "title": "Vector search latency (ms)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        { "expr": "memoryarena_vector_latency_ms{quantile=\"0.95\"}", "legendFormat": "p95" }
      ]
    },
    {
      "id": 3,
      "title": "Analytics cache hit ratio",
      "type": "stat",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "sum(rate(memoryarena_cache_hit_analytics[5m])) / clamp_min(sum(rate(memoryarena_cache_hit_analytics[5m])) + sum(rate(memoryarena_cache_miss_analytics[5m])), 1)",
          "legendFormat": "hit ratio"
        }
      ]
    },
    {
      "id": 4,
      "title": "Intelligence actions (rate/min)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 16, "x": 8, "y": 8 },
      "targets": [
        { "expr": "rate(memoryarena_memories_promoted_total[5m]) * 60", "legendFormat": "promoted" },
        { "expr": "rate(memoryarena_memories_forgotten_total[5m]) * 60", "legendFormat": "forgotten" },
        { "expr": "rate(memoryarena_memories_clustered_total[5m]) * 60", "legendFormat": "clustered" },
        { "expr": "rate(memoryarena_memories_importance_evolved_total[5m]) * 60", "legendFormat": "evolved" }
      ]
    },
    {
      "id": 5,
      "title": "Maintenance lock skips (1h)",
      "type": "stat",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 16 },
      "targets": [
        { "expr": "increase(memoryarena_intelligence_maintenance_skipped_total[1h])", "legendFormat": "skips" }
      ]
    },
    {
      "id": 6,
      "title": "Clustering pair comparisons (rate)",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 16, "x": 8, "y": 16 },
      "targets": [
        { "expr": "rate(memoryarena_clustering_pair_comparisons_total[5m])", "legendFormat": "comparisons/s" }
      ]
    }
  ]
}
