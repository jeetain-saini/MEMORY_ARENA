# =============================================================================
# MemoryArena — Environment Template
# Copy to `.env` and fill in real values. NEVER commit the populated `.env`.
#
# Two kinds of variables live here:
#   1. Container provisioning vars (POSTGRES_USER, NEO4J_PASSWORD, ...) consumed
#      by docker-compose to initialise the datastore containers.
#   2. Application connection vars (POSTGRES_URL, REDIS_URL, NEO4J_URI, ...) read
#      by backend/app/core/config.py — these must stay consistent with #1.
# =============================================================================

# ----------------------------------------------------------------------------
# Application
# ----------------------------------------------------------------------------
APP_NAME=MemoryArena
APP_ENV=development              # development | staging | production
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
VERSION=0.1.0
LOG_LEVEL=INFO                   # DEBUG | INFO | WARNING | ERROR | CRITICAL
API_V1_PREFIX=/api/v1
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ----------------------------------------------------------------------------
# PostgreSQL + pgvector
# ----------------------------------------------------------------------------
# (1) container provisioning
POSTGRES_USER=memoryarena
POSTGRES_PASSWORD=change-me
POSTGRES_DB=memoryarena
POSTGRES_PORT=5432
# (2) application connection — async SQLAlchemy URL
POSTGRES_URL=postgresql+asyncpg://memoryarena:change-me@postgres:5432/memoryarena
POSTGRES_POOL_SIZE=20
POSTGRES_MAX_OVERFLOW=10

# ----------------------------------------------------------------------------
# Redis
# ----------------------------------------------------------------------------
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0
REDIS_MAX_CONNECTIONS=50

# ----------------------------------------------------------------------------
# Neo4j
# ----------------------------------------------------------------------------
# (1) container provisioning (NEO4J_AUTH is built from USER/PASSWORD in compose)
NEO4J_USER=neo4j
# (2) application connection
NEO4J_URI=bolt://neo4j:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=change-me
NEO4J_DATABASE=neo4j

# ----------------------------------------------------------------------------
# LLM / Embeddings
# ----------------------------------------------------------------------------
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# LLM generation provider (agent answers + extraction):
#   deterministic = offline, no API key (default)
#   openai        = OpenAI (requires OPENAI_API_KEY; LLM_MODEL e.g. gpt-4o-mini)
#   anthropic     = Anthropic (requires ANTHROPIC_API_KEY; LLM_MODEL a Claude id)
#   nvidia        = NVIDIA NIM via ChatNVIDIA (requires NVIDIA_API_KEY +
#                   the langchain-nvidia-ai-endpoints package; LLM_MODEL a NIM id)
# To enable NVIDIA NIM, set NVIDIA_API_KEY below and keep LLM_PROVIDER=nvidia.
# (Leave LLM_PROVIDER unset/deterministic for the offline default.)
NVIDIA_API_KEY=
LLM_PROVIDER=nvidia
LLM_MODEL=minimaxai/minimax-m3

# Embedding pipeline (Stage 6). Provider: hash | openai | bge
#   hash   = deterministic, offline, dependency-free (dev/test default)
#   openai = OpenAI embeddings (requires OPENAI_API_KEY)
#   bge    = local sentence-transformers BGE model
EMBEDDING_PROVIDER=hash
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536


# ----------------------------------------------------------------------------
# Observability (Stage 13)
# ----------------------------------------------------------------------------
# Trace recorder for query-time request traces: in_memory | noop
#   in_memory = bounded ring buffer, recent traces readable via
#               GET /api/v1/observability/traces (default)
#   noop      = discard traces (zero overhead)
TRACE_RECORDER=in_memory
TRACE_RECORDER_CAPACITY=200
# Optional LangSmith export — OFF by default. When true, the langsmith package
# is imported lazily and traces are shipped to LangSmith (takes precedence over
# TRACE_RECORDER). Leave disabled for offline/dev/test.
LANGSMITH_ENABLED=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=memoryarena


# ----------------------------------------------------------------------------
# Security
# ----------------------------------------------------------------------------
# Must be a long random string of at least 16 chars and must NOT start with "change-me".
JWT_SECRET=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ----------------------------------------------------------------------------
# Frontend (Next.js)
# ----------------------------------------------------------------------------
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_APP_NAME=MemoryArena
